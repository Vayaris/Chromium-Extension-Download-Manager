{
  "manifest_version": 3,
  "name": "Download Manager",
  "version": "2.0.0",
  "description": "Envoie les liens magnet et fichiers .torrent directement vers votre Download Manager en un clic droit.",
  "permissions": [
    "contextMenus",
    "storage",
    "notifications",
    "windows"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["picker/picker.html", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
